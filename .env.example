# Database (PostgreSQL or SQLite)
# For SQLite (default for local dev): file:./dev.db
# For PostgreSQL: postgresql://user:pass@localhost:5432/super_market
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# Stripe (optional for MVP — checkout falls back to mock if missing)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Site config
NEXT_PUBLIC_SITE_NAME="مارکت سوپر"
COMMISSION_RATE="0.10"           # 10% platform commission
COURIER_SERVICE_FEE="20000"      # base courier service fee in IRR/cents
