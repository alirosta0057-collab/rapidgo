# Database (PostgreSQL)
# Local: postgresql://user:pass@localhost:5432/super_market
# Neon (free):  https://console.neon.tech → copy connection string
# Supabase:     https://supabase.com → Project Settings → Database → URI
# Vercel Postgres: auto-injected as POSTGRES_PRISMA_URL — copy into DATABASE_URL
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# Stripe (optional for MVP — checkout falls back to mock if missing)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Site config
NEXT_PUBLIC_SITE_NAME="مارکت سوپر"
COMMISSION_RATE="0.10"           # 10% platform commission
COURIER_SERVICE_FEE="20000"      # base courier service fee in IRR/cents

# Cloudinary (image uploads). Either set CLOUDINARY_URL or the three vars below.
CLOUDINARY_URL=""                # cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
